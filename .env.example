# Banco de dados - Railway Postgres
# Use a DATABASE_URL fornecida pelo servico Postgres do Railway.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Ambiente
NODE_ENV=production

# App
# Use a URL publica gerada no Railway, sem barra final.
APP_URL=https://seu-app.up.railway.app

# Auth
BETTER_AUTH_SECRET=change-me-use-a-random-32-plus-character-secret
BETTER_AUTH_URL=https://seu-app.up.railway.app
BETTER_AUTH_TRUSTED_ORIGINS=https://seu-app.up.railway.app

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_COMERCIAL_PRICE_ID=price_xxx

# Opcional: usado apenas por npm run db:seed:demo fora de producao.
DEMO_USER_PASSWORD=
