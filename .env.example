# Banco de dados - Railway Postgres
# Use a DATABASE_URL fornecida pelo servico Postgres do Railway.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Ambiente
NODE_ENV=production

# App
# Use a URL publica do app, sem barra final.
APP_URL=https://www.leadlink.app.br
VITE_APP_URL=https://www.leadlink.app.br

# Storage (Supabase Storage recomendado)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
PROPERTY_IMAGE_BUCKET=property-images

# Auth
BETTER_AUTH_SECRET=change-me-use-a-random-32-plus-character-secret
BETTER_AUTH_URL=https://www.leadlink.app.br
BETTER_AUTH_TRUSTED_ORIGINS=https://www.leadlink.app.br,https://leadlink.app.br

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_COMERCIAL_PRICE_ID=price_xxx

# Opcional: usado apenas por npm run db:seed:demo fora de producao.
DEMO_USER_PASSWORD=

# Opcional: quando presente, a análise de IA na extensão usa a API real do
# OpenAI (gpt-4o-mini). Sem a chave, a análise cai no modo demonstração (mock).
